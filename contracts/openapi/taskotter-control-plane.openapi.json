{
  "openapi": "3.1.0",
  "info": {
    "title": "TaskOtter Control Plane API",
    "version": "0.1.0",
    "description": "Initial TaskOtter MVP control-plane contract for first-party clients."
  },
  "servers": [
    {
      "url": "/api/v1"
    }
  ],
  "security": [
    {
      "sessionAuth": []
    }
  ],
  "paths": {
    "/users": {
      "get": {
        "operationId": "listUsers",
        "summary": "List users visible to the caller.",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkingGroupId"
          },
          {
            "$ref": "#/components/parameters/PageCursor"
          },
          {
            "$ref": "#/components/parameters/PageLimit"
          }
        ],
        "responses": {
          "200": {
            "description": "Users page.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserListResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/working-groups": {
      "get": {
        "operationId": "listWorkingGroups",
        "summary": "List Working Groups available to the caller.",
        "tags": [
          "WorkingGroups"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageCursor"
          },
          {
            "$ref": "#/components/parameters/PageLimit"
          }
        ],
        "responses": {
          "200": {
            "description": "Working Groups page.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkingGroupListResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/issues": {
      "get": {
        "operationId": "listIssues",
        "summary": "List issues scoped to a Working Group.",
        "tags": [
          "Issues"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkingGroupId"
          },
          {
            "$ref": "#/components/parameters/PageCursor"
          },
          {
            "$ref": "#/components/parameters/PageLimit"
          }
        ],
        "responses": {
          "200": {
            "description": "Issues page.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssueListResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "post": {
        "operationId": "createIssue",
        "summary": "Create an issue.",
        "tags": [
          "Issues"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateIssueRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created issue.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Issue"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/issues/{issue_id}/comments": {
      "get": {
        "operationId": "listIssueComments",
        "summary": "List comments for an issue.",
        "tags": [
          "Comments"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IssueId"
          },
          {
            "$ref": "#/components/parameters/PageCursor"
          },
          {
            "$ref": "#/components/parameters/PageLimit"
          }
        ],
        "responses": {
          "200": {
            "description": "Comments page.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommentListResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "post": {
        "operationId": "createIssueComment",
        "summary": "Create an issue comment.",
        "tags": [
          "Comments"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IssueId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCommentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created comment.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Comment"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/agents": {
      "get": {
        "operationId": "listAgents",
        "summary": "List agents scoped to a Working Group.",
        "tags": [
          "Agents"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkingGroupId"
          },
          {
            "$ref": "#/components/parameters/PageCursor"
          },
          {
            "$ref": "#/components/parameters/PageLimit"
          }
        ],
        "responses": {
          "200": {
            "description": "Agents page.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentListResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/skills": {
      "get": {
        "operationId": "listSkills",
        "summary": "List skills scoped to a Working Group.",
        "tags": [
          "Skills"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkingGroupId"
          },
          {
            "$ref": "#/components/parameters/PageCursor"
          },
          {
            "$ref": "#/components/parameters/PageLimit"
          }
        ],
        "responses": {
          "200": {
            "description": "Skills page.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkillListResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/integrations": {
      "get": {
        "operationId": "listIntegrations",
        "summary": "List integrations scoped to a Working Group.",
        "tags": [
          "Integrations"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkingGroupId"
          },
          {
            "$ref": "#/components/parameters/PageCursor"
          },
          {
            "$ref": "#/components/parameters/PageLimit"
          }
        ],
        "responses": {
          "200": {
            "description": "Integrations page.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IntegrationListResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/providers": {
      "get": {
        "operationId": "listProviders",
        "summary": "List providers scoped to a Working Group.",
        "tags": [
          "Providers"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkingGroupId"
          },
          {
            "$ref": "#/components/parameters/PageCursor"
          },
          {
            "$ref": "#/components/parameters/PageLimit"
          }
        ],
        "responses": {
          "200": {
            "description": "Providers page.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProviderListResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/workflows": {
      "get": {
        "operationId": "listWorkflows",
        "summary": "List workflows scoped to a Working Group.",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkingGroupId"
          },
          {
            "$ref": "#/components/parameters/PageCursor"
          },
          {
            "$ref": "#/components/parameters/PageLimit"
          }
        ],
        "responses": {
          "200": {
            "description": "Workflows page.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowListResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/usage/events": {
      "post": {
        "operationId": "recordUsageEvent",
        "summary": "Record a runtime usage event.",
        "tags": [
          "Usage"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UsageEvent"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Usage event accepted."
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/audit/events": {
      "get": {
        "operationId": "listAuditEvents",
        "summary": "Read audit events for a Working Group.",
        "tags": [
          "Audit"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkingGroupId"
          },
          {
            "$ref": "#/components/parameters/PageCursor"
          },
          {
            "$ref": "#/components/parameters/PageLimit"
          }
        ],
        "responses": {
          "200": {
            "description": "Audit events page.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditEventListResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "sessionAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "taskotter_session"
      }
    },
    "parameters": {
      "WorkingGroupId": {
        "name": "working_group_id",
        "in": "query",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/WorkingGroupId"
        }
      },
      "IssueId": {
        "name": "issue_id",
        "in": "path",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/IssueId"
        }
      },
      "PageCursor": {
        "name": "cursor",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "PageLimit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 25
        }
      },
      "IdempotencyKey": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string",
          "minLength": 16,
          "maxLength": 128
        }
      }
    },
    "responses": {
      "Error": {
        "description": "Error response.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        }
      }
    },
    "schemas": {
      "ResourceId": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*_[0-9A-HJKMNP-TV-Z]{26}$",
        "examples": [
          "iss_01J9Z4P4BS0M9P2QJ6T8Z6W2EP"
        ]
      },
      "WorkingGroupId": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ResourceId"
          }
        ],
        "examples": [
          "wg_01J9Z4P4BS0M9P2QJ6T8Z6W2EP"
        ]
      },
      "IssueId": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ResourceId"
          }
        ],
        "examples": [
          "iss_01J9Z4P4BS0M9P2QJ6T8Z6W2EP"
        ]
      },
      "ActorRef": {
        "type": "object",
        "required": [
          "type",
          "id"
        ],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "user",
              "agent",
              "service"
            ]
          },
          "id": {
            "$ref": "#/components/schemas/ResourceId"
          }
        }
      },
      "PageInfo": {
        "type": "object",
        "required": [
          "has_more"
        ],
        "additionalProperties": false,
        "properties": {
          "next_cursor": {
            "type": "string"
          },
          "has_more": {
            "type": "boolean"
          }
        }
      },
      "User": {
        "type": "object",
        "required": [
          "id",
          "primary_email",
          "display_name",
          "status",
          "created_at"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "$ref": "#/components/schemas/ResourceId"
          },
          "primary_email": {
            "type": "string",
            "format": "email"
          },
          "display_name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "invited",
              "suspended"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "WorkingGroup": {
        "type": "object",
        "required": [
          "id",
          "name",
          "slug",
          "status",
          "created_at"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "$ref": "#/components/schemas/WorkingGroupId"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "archived"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Issue": {
        "type": "object",
        "required": [
          "id",
          "working_group_id",
          "title",
          "status",
          "priority",
          "created_at",
          "updated_at"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "$ref": "#/components/schemas/IssueId"
          },
          "working_group_id": {
            "$ref": "#/components/schemas/WorkingGroupId"
          },
          "parent_issue_id": {
            "$ref": "#/components/schemas/IssueId"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "todo",
              "in_progress",
              "in_review",
              "done",
              "blocked",
              "backlog",
              "cancelled"
            ]
          },
          "priority": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "urgent"
            ]
          },
          "assignee": {
            "$ref": "#/components/schemas/ActorRef"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Comment": {
        "type": "object",
        "required": [
          "id",
          "working_group_id",
          "issue_id",
          "author",
          "body",
          "created_at"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "$ref": "#/components/schemas/ResourceId"
          },
          "working_group_id": {
            "$ref": "#/components/schemas/WorkingGroupId"
          },
          "issue_id": {
            "$ref": "#/components/schemas/IssueId"
          },
          "author": {
            "$ref": "#/components/schemas/ActorRef"
          },
          "body": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "NamedScopedResource": {
        "type": "object",
        "required": [
          "id",
          "working_group_id",
          "name",
          "status",
          "created_at"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "$ref": "#/components/schemas/ResourceId"
          },
          "working_group_id": {
            "$ref": "#/components/schemas/WorkingGroupId"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "disabled",
              "archived"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Agent": {
        "allOf": [
          {
            "$ref": "#/components/schemas/NamedScopedResource"
          }
        ]
      },
      "Skill": {
        "allOf": [
          {
            "$ref": "#/components/schemas/NamedScopedResource"
          }
        ]
      },
      "Integration": {
        "allOf": [
          {
            "$ref": "#/components/schemas/NamedScopedResource"
          }
        ]
      },
      "Provider": {
        "allOf": [
          {
            "$ref": "#/components/schemas/NamedScopedResource"
          }
        ]
      },
      "Workflow": {
        "allOf": [
          {
            "$ref": "#/components/schemas/NamedScopedResource"
          }
        ]
      },
      "UsageEvent": {
        "$ref": "../schemas/usage-event.schema.json"
      },
      "AuditEvent": {
        "$ref": "../schemas/audit-event.schema.json"
      },
      "CreateIssueRequest": {
        "type": "object",
        "required": [
          "working_group_id",
          "title"
        ],
        "additionalProperties": false,
        "properties": {
          "working_group_id": {
            "$ref": "#/components/schemas/WorkingGroupId"
          },
          "parent_issue_id": {
            "$ref": "#/components/schemas/IssueId"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "urgent"
            ],
            "default": "medium"
          }
        }
      },
      "CreateCommentRequest": {
        "type": "object",
        "required": [
          "working_group_id",
          "body"
        ],
        "additionalProperties": false,
        "properties": {
          "working_group_id": {
            "$ref": "#/components/schemas/WorkingGroupId"
          },
          "body": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "ErrorEnvelope": {
        "type": "object",
        "required": [
          "error"
        ],
        "additionalProperties": false,
        "properties": {
          "error": {
            "type": "object",
            "required": [
              "code",
              "message",
              "request_id",
              "retryable"
            ],
            "additionalProperties": false,
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "details": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "request_id": {
                "type": "string"
              },
              "retryable": {
                "type": "boolean"
              }
            }
          }
        }
      },
      "UserListResponse": {
        "$ref": "#/components/schemas/UserPage"
      },
      "WorkingGroupListResponse": {
        "$ref": "#/components/schemas/WorkingGroupPage"
      },
      "IssueListResponse": {
        "$ref": "#/components/schemas/IssuePage"
      },
      "CommentListResponse": {
        "$ref": "#/components/schemas/CommentPage"
      },
      "AgentListResponse": {
        "$ref": "#/components/schemas/AgentPage"
      },
      "SkillListResponse": {
        "$ref": "#/components/schemas/SkillPage"
      },
      "IntegrationListResponse": {
        "$ref": "#/components/schemas/IntegrationPage"
      },
      "ProviderListResponse": {
        "$ref": "#/components/schemas/ProviderPage"
      },
      "WorkflowListResponse": {
        "$ref": "#/components/schemas/WorkflowPage"
      },
      "AuditEventListResponse": {
        "$ref": "#/components/schemas/AuditEventPage"
      },
      "UserPage": {
        "$ref": "#/components/schemas/PageOfUser"
      },
      "WorkingGroupPage": {
        "$ref": "#/components/schemas/PageOfWorkingGroup"
      },
      "IssuePage": {
        "$ref": "#/components/schemas/PageOfIssue"
      },
      "CommentPage": {
        "$ref": "#/components/schemas/PageOfComment"
      },
      "AgentPage": {
        "$ref": "#/components/schemas/PageOfAgent"
      },
      "SkillPage": {
        "$ref": "#/components/schemas/PageOfSkill"
      },
      "IntegrationPage": {
        "$ref": "#/components/schemas/PageOfIntegration"
      },
      "ProviderPage": {
        "$ref": "#/components/schemas/PageOfProvider"
      },
      "WorkflowPage": {
        "$ref": "#/components/schemas/PageOfWorkflow"
      },
      "AuditEventPage": {
        "$ref": "#/components/schemas/PageOfAuditEvent"
      },
      "PageOfUser": {
        "type": "object",
        "required": [
          "data",
          "page"
        ],
        "additionalProperties": false,
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          },
          "page": {
            "$ref": "#/components/schemas/PageInfo"
          }
        }
      },
      "PageOfWorkingGroup": {
        "type": "object",
        "required": [
          "data",
          "page"
        ],
        "additionalProperties": false,
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkingGroup"
            }
          },
          "page": {
            "$ref": "#/components/schemas/PageInfo"
          }
        }
      },
      "PageOfIssue": {
        "type": "object",
        "required": [
          "data",
          "page"
        ],
        "additionalProperties": false,
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Issue"
            }
          },
          "page": {
            "$ref": "#/components/schemas/PageInfo"
          }
        }
      },
      "PageOfComment": {
        "type": "object",
        "required": [
          "data",
          "page"
        ],
        "additionalProperties": false,
        "properties": {
          "data": {
