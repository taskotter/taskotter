{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.taskotter.dev/usage-event.schema.json",
  "title": "TaskOtterUsageEvent",
  "type": "object",
  "required": [
    "id",
    "type",
    "version",
    "occurred_at",
    "source",
    "working_group_id",
    "actor",
    "resource",
    "correlation_id",
    "request_id",
    "policy_decision_id",
    "idempotency_key",
    "payload"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "#/$defs/eventId"
    },
    "type": {
      "const": "usage.gateway_request.recorded"
    },
    "version": {
      "const": "0.1.0"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": [
        "control_plane",
        "runner",
        "gateway"
      ]
    },
    "working_group_id": {
      "$ref": "#/$defs/workingGroupId"
    },
    "actor": {
      "$ref": "#/$defs/actorRef"
    },
    "resource": {
      "$ref": "#/$defs/resourceRef"
    },
    "correlation_id": {
      "$ref": "#/$defs/correlationId"
    },
    "request_id": {
      "$ref": "#/$defs/requestId"
    },
    "policy_decision_id": {
      "$ref": "#/$defs/policyDecisionId"
    },
    "idempotency_key": {
      "$ref": "#/$defs/idempotencyKey"
    },
    "reservation_id": {
      "$ref": "#/$defs/reservationId"
    },
    "status": {
      "$ref": "#/$defs/usageAttemptStatus"
    },
    "denial_reason": {
      "$ref": "#/$defs/denialReason"
    },
    "payload": {
      "type": "object",
      "required": [
        "subject",
        "measurements"
      ],
      "additionalProperties": false,
      "properties": {
        "subject": {
          "$ref": "#/$defs/usageSubjectRef"
        },
        "measurements": {
          "type": "object",
          "required": [
            "duration_ms"
          ],
          "additionalProperties": false,
          "properties": {
            "duration_ms": {
              "type": "integer",
              "minimum": 0
            },
            "input_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "output_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "tool_invocations": {
              "type": "integer",
              "minimum": 0
            },
            "estimated_cost_micros": {
              "type": "integer",
              "minimum": 0
            },
            "actual_cost_micros": {
              "type": "integer",
              "minimum": 0
            },
            "metering_unit": {
              "$ref": "#/$defs/meteringUnit"
            },
            "runtime_capability": {
              "$ref": "#/$defs/highRiskRuntimeCapability"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "safeOpaqueRef": {
      "type": "string",
      "maxLength": 80,
      "not": {
        "pattern": "(api[_-]?key|access[_-]?token|refresh[_-]?token|private[_-]?key|client[_-]?secret|bearer |password|raw[_-]?prompt|raw[_-]?log|artifact[_-]?body|-----BEGIN|[Xx]-[Aa][Mm][Zz]-[Ss][Ii][Gg][Nn][Aa][Tt][Uu][Rr][Ee]|[Xx]-[Gg][Oo][Oo][Gg]-[Ss][Ii][Gg][Nn][Aa][Tt][Uu][Rr][Ee]|[Ss][Ii][Gg][Nn][Aa][Tt][Uu][Rr][Ee]=)"
      }
    },
    "eventId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^evt_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "workingGroupId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^wg_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "correlationId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^corr_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "requestId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^req_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "policyDecisionId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^poldec_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "idempotencyKey": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^usage_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "reservationId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^resv_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "actorRef": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "user",
            "agent",
            "service"
          ]
        },
        "id": {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "user"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^usr_[0-9A-HJKMNP-TV-Z]{26}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "agent"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^agt_[0-9A-HJKMNP-TV-Z]{26}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "service"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^svc_[0-9A-HJKMNP-TV-Z]{26}$"
              }
            }
          }
        }
      ]
    },
    "resourceRef": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "provider",
            "mcp_server",
            "runner",
            "job",
            "integration"
          ]
        },
        "id": {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "provider"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^prv_[0-9A-HJKMNP-TV-Z]{26}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "mcp_server"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^mcp_[0-9A-HJKMNP-TV-Z]{26}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "runner"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^runr_[0-9A-HJKMNP-TV-Z]{26}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "job"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^job_[0-9A-HJKMNP-TV-Z]{26}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "integration"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^int_[0-9A-HJKMNP-TV-Z]{26}$"
              }
            }
          }
        }
      ]
    },
    "usageSubjectRef": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "agent_run",
            "gateway_request",
            "workflow_run",
            "runner_job"
          ]
        },
        "id": {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "agent_run"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^run_[0-9A-HJKMNP-TV-Z]{26}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "gateway_request"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^gwreq_[0-9A-HJKMNP-TV-Z]{26}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "workflow_run"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^wfrun_[0-9A-HJKMNP-TV-Z]{26}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "runner_job"
              }
            }
          },
          "then": {
            "properties": {
              "id": {
                "pattern": "^job_[0-9A-HJKMNP-TV-Z]{26}$"
              }
            }
          }
        }
      ]
    },
    "usageAttemptStatus": {
      "type": "string",
      "enum": [
        "succeeded",
        "denied",
        "timeout",
        "cancelled",
        "failed"
      ]
    },
    "denialReason": {
      "type": "string",
      "maxLength": 80,
      "enum": [
        "policy_denied",
        "usage_limit_reached",
        "protected_capability_disabled",
        "quota_exceeded"
      ]
    },
    "highRiskRuntimeCapability": {
      "type": "string",
      "maxLength": 80,
      "enum": [
        "remote.local_tool_execution",
        "remote.local_llm_exposure",
        "remote.external_agent_runtime_adapter",
        "remote.computer_use_execution",
        "gateway.hosted_mcp_billing",
        "gateway.sensitive_provider_routing"
      ]
    },
    "meteringUnit": {
      "type": "string",
      "enum": [
        "request",
        "tool_invocation",
        "runtime_ms",
        "local_compute_ms",
        "hosted_mcp_runtime_ms",
        "token"
      ]
    }
  }
}
