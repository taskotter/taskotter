{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.taskotter.dev/audit-chain-fixture.schema.json",
  "title": "TaskOtterAuditChainFixture",
  "type": "object",
  "required": [
    "schema_version",
    "description",
    "chain",
    "cross_repo_evidence",
    "events",
    "residual_risk"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "audit-chain-fixture@0.1.0"
    },
    "description": {
      "type": "string"
    },
    "chain": {
      "type": "object",
      "required": [
        "correlation_id",
        "request_id",
        "working_group_id",
        "actor",
        "run_id",
        "job_id",
        "runner_id",
        "gateway_request_id",
        "mcp_server_id",
        "policy_decision_id",
        "approval_id"
      ],
      "additionalProperties": false,
      "properties": {
        "correlation_id": {
          "$ref": "#/$defs/correlationId"
        },
        "request_id": {
          "$ref": "#/$defs/requestId"
        },
        "working_group_id": {
          "$ref": "#/$defs/workingGroupId"
        },
        "actor": {
          "$ref": "#/$defs/actorRef"
        },
        "run_id": {
          "$ref": "#/$defs/runId"
        },
        "job_id": {
          "$ref": "#/$defs/jobId"
        },
        "runner_id": {
          "$ref": "#/$defs/runnerId"
        },
        "gateway_request_id": {
          "$ref": "#/$defs/gatewayRequestId"
        },
        "mcp_server_id": {
          "$ref": "#/$defs/mcpServerId"
        },
        "policy_decision_id": {
          "$ref": "#/$defs/policyDecisionId"
        },
        "approval_id": {
          "$ref": "#/$defs/approvalId"
        }
      }
    },
    "cross_repo_evidence": {
      "type": "object",
      "required": [
        "remote",
        "gateway"
      ],
      "additionalProperties": false,
      "properties": {
        "remote": {
          "type": "object",
          "required": [
            "repo",
            "protocol_version",
            "message_type",
            "fixture_path",
            "lineage_model",
            "required_control_plane_join_keys",
            "dispatch_payload_lineage"
          ],
          "additionalProperties": false,
          "properties": {
            "repo": {
              "const": "taskotter/taskotter-remote"
            },
            "protocol_version": {
              "const": "remote.v1alpha1"
            },
            "message_type": {
              "const": "job.dispatch"
            },
            "fixture_path": {
              "type": "string"
            },
            "lineage_model": {
              "const": "dispatch_fragment_requires_control_plane_join"
            },
            "required_control_plane_join_keys": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "correlation_id",
                  "request_id",
                  "working_group_id",
                  "policy_decision_id",
                  "job_id",
                  "runner_id"
                ]
              },
              "minItems": 6
            },
            "dispatch_payload_lineage": {
              "type": "object",
              "required": [
                "has_correlation_id",
                "has_request_id",
                "has_policy_decision_id",
                "has_working_group_id"
              ],
              "additionalProperties": false,
              "properties": {
                "has_correlation_id": {
                  "const": true
                },
                "has_request_id": {
                  "const": false
                },
                "has_policy_decision_id": {
                  "const": false
                },
                "has_working_group_id": {
                  "const": true
                }
              }
            }
          }
        },
        "gateway": {
          "type": "object",
          "required": [
            "repo",
            "protocol_version",
            "request_fixtures",
            "event_fixtures"
          ],
          "additionalProperties": false,
          "properties": {
            "repo": {
              "const": "taskotter/taskotter-gateway"
            },
            "protocol_version": {
              "const": "gateway.v0.1"
            },
            "request_fixtures": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 2
            },
            "event_fixtures": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 2
            }
          }
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/chainEvent"
      },
      "minItems": 10
    },
    "residual_risk": {
      "type": "object",
      "required": [
        "export_delete_retention",
        "security_review_trigger",
        "security_review_reason"
      ],
      "additionalProperties": false,
      "properties": {
        "export_delete_retention": {
          "type": "string"
        },
        "security_review_trigger": {
          "const": true
        },
        "security_review_reason": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "safeOpaqueRef": {
      "type": "string",
      "maxLength": 120,
      "not": {
        "pattern": "(api[_-]?key|access[_-]?token|refresh[_-]?token|private[_-]?key|client[_-]?secret|bearer |password|raw[_-]?prompt|raw[_-]?log|artifact[_-]?body|-----BEGIN)"
      }
    },
    "eventId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^evt_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "correlationId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^corr_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "requestId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^req_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "workingGroupId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^wg_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "runId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^run_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "jobId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^job_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "runnerId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^runr_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "gatewayRequestId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^gwreq_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "mcpServerId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^mcp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "policyDecisionId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^poldec_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "approvalId": {
      "allOf": [
        {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      ],
      "pattern": "^appr_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "actorRef": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "user",
            "agent",
            "service"
          ]
        },
        "id": {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      }
    },
    "resourceRef": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "agent_run",
            "approval",
            "gateway_request",
            "job",
            "mcp_server",
            "provider",
            "runner"
          ]
        },
        "id": {
          "$ref": "#/$defs/safeOpaqueRef"
        }
      }
    },
    "chainEvent": {
      "type": "object",
      "required": [
        "stage",
        "event_shape",
        "id",
        "type",
        "version",
        "occurred_at",
        "source",
        "working_group_id",
        "actor",
        "resource",
        "correlation_id",
        "request_id",
        "redaction",
        "payload"
      ],
      "additionalProperties": false,
      "properties": {
        "stage": {
          "type": "string",
          "enum": [
            "user_request",
            "policy_decision",
            "approval_requested",
            "runner_dispatch",
            "gateway_request",
            "mcp_call_denied",
            "usage_event",
            "audit_event",
            "artifact_log_event",
            "final_result"
          ]
        },
        "event_shape": {
          "type": "string",
          "enum": [
            "summary_event",
            "canonical_event_reference"
          ]
        },
        "canonical_schema_path": {
          "type": "string"
        },
        "canonical_fixture_path": {
          "type": "string"
        },
        "id": {
          "$ref": "#/$defs/eventId"
        },
        "type": {
          "type": "string",
          "pattern": "^[a-z0-9]+(\\.[a-z0-9_]+)+$"
        },
        "version": {
          "const": "0.1.0"
        },
        "occurred_at": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "control_plane",
            "runner",
            "gateway"
          ]
        },
        "working_group_id": {
          "$ref": "#/$defs/workingGroupId"
        },
        "actor": {
          "$ref": "#/$defs/actorRef"
        },
        "resource": {
          "$ref": "#/$defs/resourceRef"
        },
        "correlation_id": {
          "$ref": "#/$defs/correlationId"
        },
        "request_id": {
          "$ref": "#/$defs/requestId"
        },
        "policy_decision_id": {
          "$ref": "#/$defs/policyDecisionId"
        },
        "approval_id": {
          "$ref": "#/$defs/approvalId"
        },
        "protocol_version": {
          "type": "string",
          "enum": [
            "remote.v1alpha1",
            "gateway.v0.1"
          ]
        },
        "redaction": {
          "type": "string",
          "enum": [
            "internal_reference_only",
            "redacted_summary"
          ]
        },
        "payload": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "event_shape": {
                "const": "canonical_event_reference"
              }
            }
          },
          "then": {
            "required": [
              "canonical_schema_path",
              "canonical_fixture_path",
              "policy_decision_id"
            ]
          }
        }
      ]
    }
  }
}
