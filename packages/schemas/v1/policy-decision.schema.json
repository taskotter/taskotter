{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.taskotter.dev/v1/policy-decision.schema.json",
  "title": "PolicyDecision",
  "type": "object",
  "required": ["decision_id", "request_id", "scope", "effect", "constraints", "expires_at_unix_seconds"],
  "additionalProperties": false,
  "properties": {
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "required": ["working_group_id", "actions"],
      "additionalProperties": false,
      "properties": {
        "working_group_id": {
          "type": "string",
          "minLength": 1
        },
        "resource_id": {
          "type": ["string", "null"]
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "common.schema.json#/$defs/action"
          }
        }
      }
    },
    "effect": {
      "type": "string",
      "enum": ["allow", "deny"]
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "effect", "reason"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "effect": {
            "type": "string",
            "enum": ["allow", "deny"]
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "expires_at_unix_seconds": {
      "type": "integer",
      "minimum": 0
    }
  }
}
