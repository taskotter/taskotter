{
  "name": "taskotter",
  "private": true,
  "version": "0.1.0",
  "description": "TaskOtter control plane contract and product workspace scaffold.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "preview": "vite preview",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "contracts:generate": "node scripts/generate-contracts.mjs",
    "contracts:check": "node scripts/generate-contracts.mjs --check",
    "test:compatibility": "node scripts/check-contract-compatibility.mjs",
    "check:module-boundaries": "node scripts/check-module-boundaries.mjs",
    "test:fixtures": "node --test tests/contracts/*.test.mjs",
    "test:unit": "vitest run",
    "test": "npm run contracts:check && npm run check:module-boundaries && npm run test:fixtures && npm run test:compatibility && npm run test:unit",
    "test:ui": "playwright test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^0.468.0",
    "vite": "^8.0.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22"
  }
}
